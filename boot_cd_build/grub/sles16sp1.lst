color white/blue black/light-gray
default 0
timeout 30
root (cd)
gfxmenu /grub/message

title back
        configfile /grub/instserver.lst

title SLES16SP1 Agama
	kernel /kernel/sles16sp1/linux inst.info=http://autoyast.suse/autoyast/info-sles16sp1.txt root=live:http://autoyast.suse/sles16sp1/LiveOS/squashfs.img live.net_config_tui=1
	initrd=/kernel/sles16sp1/initrd

#title SLES16SP1 AutoYaST
